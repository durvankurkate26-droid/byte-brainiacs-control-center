# Copy this file to .env.local and fill in values from:
# Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service-role key — used ONLY by server routes (e.g. participant import) to
# perform privileged writes the anon client is denied by RLS.
# Supabase Dashboard → Project Settings → API → service_role.
# Keep this secret: it bypasses RLS. Never prefix it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Admin authentication ─────────────────────────────────────────────────────
# Credentials for the password-protected admin dashboard. Server-only — these
# must NEVER be prefixed with NEXT_PUBLIC_ and are never sent to the browser.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Optional. Secret used to sign the session cookie. If omitted, a secret is
# derived from ADMIN_USERNAME/ADMIN_PASSWORD (rotating the password then
# invalidates all existing sessions). Set an explicit value to control session
# invalidation independently of the password.
# AUTH_SECRET=a-long-random-string
